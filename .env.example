# Enterprise CRM Portal - Environment Configuration
# Copy to .env and fill in the REQUIRED values. Everything else has sane defaults.
#
# STANDALONE MODE (not part of OCI-DEMO):
#   Set DNS_DOMAIN + Oracle credentials. That's the minimum.
#   IDCS SSO is optional — local auth (admin/admin123) works without it.
#   OCI APM is optional — the app works without telemetry export.
#
# OCI-DEMO MODE:
#   The c27_deploy_enterprise_crm.sh script fills these from the OCI-DEMO
#   environment. You don't need to touch this file.

# ── REQUIRED ──────────────────────────────────────────────────────

# DNS domain for deriving public URLs (e.g., crm.<DNS_DOMAIN>)
# This is the ONLY domain-related config you need to set.
DNS_DOMAIN=

# Oracle ATP credentials
ORACLE_DSN=                        # e.g., myatp_low (from tnsnames.ora)
ORACLE_USER=ADMIN
ORACLE_PASSWORD=                   # ATP admin password
ORACLE_WALLET_DIR=                 # path to unzipped wallet (e.g., /app/wallet)
ORACLE_WALLET_PASSWORD=            # wallet password

# ── APPLICATION ───────────────────────────────────────────────────

APP_NAME=enterprise-crm-portal
BRAND_NAME=Enterprise CRM
APP_VERSION=1.1.0
APP_PORT=8080
APP_ENV=production
APP_SECRET_KEY=change-me-in-production
APP_RUNTIME=docker
SERVICE_NAMESPACE=crm
DEMO_STACK_NAME=enterprise-crm

# ── DATABASE POOL ─────────────────────────────────────────────────

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_AUTH_POOL_SIZE=5
DB_AUTH_MAX_OVERFLOW=10
DB_AUTH_POOL_TIMEOUT=5
AUTH_EXECUTOR_MAX_WORKERS=15
ATP_OCID=
DATABASE_OBSERVABILITY_ENABLED=true

# ── OCI APM — OpenTelemetry (optional) ────────────────────────────

OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OTEL_SERVICE_NAME=enterprise-crm-portal
OTLP_LOG_EXPORT_ENABLED=false

# OCI APM — RUM (optional)
OCI_APM_RUM_ENDPOINT=
OCI_APM_RUM_PUBLIC_DATAKEY=

# OCI Logging (optional)
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
OCI_AUTH_MODE=instance_principal

# Splunk HEC (optional)
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# ── CROSS-SERVICE INTEGRATION (optional) ──────────────────────────

# Drone shop URL — enables order sync and simulation proxy.
# In OKE: http://octo-drone-shop.octo-drone-shop.svc.cluster.local
# External: https://shop.<DNS_DOMAIN>
OCTO_DRONE_SHOP_URL=
EXTERNAL_ORDERS_URL=
EXTERNAL_ORDERS_PATH=/api/orders
ORDERS_SYNC_ENABLED=true
ORDERS_SYNC_INTERVAL_SECONDS=300
ORDERS_SYNC_SOURCE_NAME=octo-drone-shop
SUSPICIOUS_ORDER_TOTAL_THRESHOLD=50000
BACKLOG_ORDER_AGE_MINUTES=30

# Cross-service simulation proxy key (shared with drone shop)
# Auto-derived by the OCI-DEMO deploy script; set manually for standalone.
INTERNAL_SERVICE_KEY=

# OCI console deep links (optional — populates the Integrations page)
APM_CONSOLE_URL=
OPSI_CONSOLE_URL=
DB_MANAGEMENT_CONSOLE_URL=
LOG_ANALYTICS_CONSOLE_URL=

# ── SECURITY ──────────────────────────────────────────────────────

SECURITY_LOG_ENABLED=true
SESSION_TIMEOUT_SECONDS=3600
MAX_LOGIN_ATTEMPTS=5

# ── IDCS / OCI Identity Domain SSO (optional) ────────────────────
# When configured, a "Sign in with OCI Identity (SSO)" button appears.
# When not configured, only local auth (admin/admin123) is available.

IDCS_DOMAIN_URL=
IDCS_CLIENT_ID=
IDCS_CLIENT_SECRET=
# Auto-derived from DNS_DOMAIN or CRM_BASE_URL — only set if you need
# to override (e.g., custom ingress path).
# IDCS_REDIRECT_URI=

# ── CHAOS / ISSUE SIMULATION (runtime toggleable) ────────────────

SIMULATE_DB_LATENCY=false
SIMULATE_DB_DISCONNECT=false
SIMULATE_MEMORY_LEAK=false
SIMULATE_CPU_SPIKE=false
SIMULATE_SLOW_QUERIES=false
