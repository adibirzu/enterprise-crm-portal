# Enterprise CRM Portal - Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=enterprise-crm-portal
BRAND_NAME=OCTO CRM APM
APP_VERSION=1.1.0
APP_PORT=8080
APP_ENV=production
APP_SECRET_KEY=change-me-in-production
APP_RUNTIME=docker
SERVICE_NAMESPACE=octo
SERVICE_INSTANCE_ID=local-dev
DEMO_STACK_NAME=octo-apm

# Database
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@postgres:5432/crm_db
DATABASE_SYNC_URL=postgresql://crm_user:crm_password@postgres:5432/crm_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
ATP_OCID=
ATP_CONNECTION_NAME=ATPAdi
ATP_WALLET_DIR=
ATP_TNS_NAME=
DATABASE_OBSERVABILITY_ENABLED=true

# OCI APM - OpenTelemetry
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OTEL_SERVICE_NAME=enterprise-crm-portal
OTLP_LOG_EXPORT_ENABLED=true

# OCI APM - RUM (Real User Monitoring)
OCI_APM_RUM_ENDPOINT=
OCI_APM_RUM_PUBLIC_DATAKEY=

# OCI Logging
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
OCI_AUTH_MODE=instance_principal

# Splunk HEC (optional)
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Cross-service dependencies
MUSHOP_CLOUDNATIVE_URL=
OCTO_APM_CLOUDNATIVE_URL=
OCI_DEMO_CONTROL_PLANE_URL=
OCI_DEMO_BACKEND_URL=
APM_CONSOLE_URL=
OPSI_CONSOLE_URL=
DB_MANAGEMENT_CONSOLE_URL=
LOG_ANALYTICS_CONSOLE_URL=

# Security settings
SECURITY_LOG_ENABLED=true
SESSION_TIMEOUT_SECONDS=3600
MAX_LOGIN_ATTEMPTS=5

# Chaos / Issue Simulation
SIMULATE_DB_LATENCY=false
SIMULATE_DB_DISCONNECT=false
SIMULATE_MEMORY_LEAK=false
SIMULATE_CPU_SPIKE=false
SIMULATE_SLOW_QUERIES=false
