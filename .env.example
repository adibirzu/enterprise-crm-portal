# Enterprise CRM Portal - Environment Configuration
# Copy to .env and fill in values

# Application
APP_NAME=enterprise-crm-portal
APP_PORT=8080
APP_ENV=production
APP_SECRET_KEY=change-me-in-production
APP_RUNTIME=docker

# Database
DATABASE_URL=postgresql+asyncpg://crm_user:crm_password@postgres:5432/crm_db
DATABASE_SYNC_URL=postgresql://crm_user:crm_password@postgres:5432/crm_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# OCI APM - OpenTelemetry
OCI_APM_ENDPOINT=
OCI_APM_PRIVATE_DATAKEY=
OCI_APM_PUBLIC_DATAKEY=
OTEL_SERVICE_NAME=enterprise-crm-portal

# OCI APM - RUM (Real User Monitoring)
OCI_APM_RUM_ENDPOINT=
OCI_APM_RUM_PUBLIC_DATAKEY=

# OCI Logging
OCI_LOG_ID=
OCI_LOG_GROUP_ID=
OCI_AUTH_MODE=instance_principal

# Splunk HEC (optional)
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# Security settings
SECURITY_LOG_ENABLED=true
SESSION_TIMEOUT_SECONDS=3600
MAX_LOGIN_ATTEMPTS=5

# Chaos / Issue Simulation
SIMULATE_DB_LATENCY=false
SIMULATE_DB_DISCONNECT=false
SIMULATE_MEMORY_LEAK=false
SIMULATE_CPU_SPIKE=false
SIMULATE_SLOW_QUERIES=false
